{
  "name": "orinocoflow",
  "version": "0.2.0",
  "description": "Minimalist TypeScript workflow engine for AI pipelines",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "oflow": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./compile": {
      "types": "./dist/cli/compile.d.ts",
      "import": "./dist/cli/compile.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/cli/index.ts src/cli/compile.ts --format esm,cjs --no-splitting --target node18 --out-dir dist && tsc --emitDeclarationOnly --noEmit false",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "tsx": "^4.0.0"
  },
  "dependencies": {
    "yaml": "^2.8.2",
    "zod": "^3.23.0"
  }
}
